<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="512dp"
    android:height="512dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <!-- Squircle Background -->
    <path android:pathData="M 144,32 L 368,32 A 112,112 0 0 1 480,144 L 480,368 A 112,112 0 0 1 368,480 L 144,480 A 112,112 0 0 1 32,368 L 32,144 A 112,112 0 0 1 144,32 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:endX="512"
                android:endY="512"
                android:startX="0"
                android:startY="0"
                android:type="linear">
                <item
                    android:color="#1E293B"
                    android:offset="0" />
                <item
                    android:color="#020617"
                    android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Squircle border -->
    <path
        android:pathData="M 144,32 L 368,32 A 112,112 0 0 1 480,144 L 480,368 A 112,112 0 0 1 368,480 L 144,480 A 112,112 0 0 1 32,368 L 32,144 A 112,112 0 0 1 144,32 Z"
        android:strokeWidth="2"
        android:strokeColor="#0DFFFFFF" />

    <!-- Top Wavy Line -->
    <path
        android:pathData="M 100,161 A 40,30 0 0,1 180,161 A 40,30 0 0,0 260,161 L 412,161"
        android:strokeWidth="40"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient android:startX="100" android:startY="0" android:endX="412" android:endY="0" android:type="linear">
                <item android:color="#76D1C1" android:offset="0" />
                <item android:color="#4ade80" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Middle Straight Line -->
    <path
        android:pathData="M 100,271 L 412,271"
        android:strokeWidth="40"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient android:startX="100" android:startY="0" android:endX="412" android:endY="0" android:type="linear">
                <item android:color="#76D1C1" android:offset="0" />
                <item android:color="#4ade80" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bottom Straight Line -->
    <path
        android:pathData="M 100,381 L 280,381"
        android:strokeWidth="40"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient android:startX="100" android:startY="0" android:endX="412" android:endY="0" android:type="linear">
                <item android:color="#76D1C1" android:offset="0" />
                <item android:color="#4ade80" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>
</vector>