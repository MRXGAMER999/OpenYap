{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "x64-debug",
      "displayName": "x64 Debug",
      "description": "Debug build targeting x64 — matches the layout VS IDE uses in out/build/x64-Debug.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/x64-debug",
      "installDir": "${sourceDir}/out/install/x64-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "x64-release",
      "displayName": "x64 Release",
      "description": "Optimised release build targeting x64. cmake --install stages the DLL to prebuilt/windows-x64/.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/x64-release",
      "installDir": "${sourceDir}/prebuilt/windows-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "x64-debug",
      "displayName": "x64 Debug",
      "configurePreset": "x64-debug"
    },
    {
      "name": "x64-release",
      "displayName": "x64 Release",
      "configurePreset": "x64-release"
    }
  ],
  "installPresets": [
    {
      "name": "x64-release",
      "displayName": "x64 Release — stage to prebuilt/",
      "configurePreset": "x64-release"
    }
  ]
}
